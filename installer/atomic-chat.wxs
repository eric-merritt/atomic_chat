<?xml version="1.0" encoding="UTF-8"?>
<!--
  Atomic Chat Agent — Windows Installer
  Builds with WiX 4: wix build installer/atomic-chat.wxs
  Requires: wix extension add WixToolset.UI.wixext
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Atomic Chat Agent"
           Manufacturer="Eric Merritt"
           Version="1.0.0"
           UpgradeCode="f3a8b1c2-d4e5-4f60-a7b8-c9d0e1f23456"
           Scope="perUser">

    <SummaryInformation Description="Atomic Chat client bridge" />

    <!-- Remove old version before installing new one -->
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />

    <!-- Embed all files into the MSI (no separate .cab) -->
    <MediaTemplate EmbedCab="yes" />

    <!-- ── Directories ──────────────────────────────────────────────────── -->

    <!-- Exe → %LOCALAPPDATA%\AtomicChat\ -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="AtomicChat" />
    </StandardDirectory>

    <!-- Shortcut → Start Menu\Atomic Chat -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="Atomic Chat" />
    </StandardDirectory>

    <!-- ── Components ──────────────────────────────────────────────────── -->

    <ComponentGroup Id="AgentBinary" Directory="INSTALLFOLDER">
      <Component Id="AgentExe" Guid="*">
        <File Source="..\dist\atomic-chat-agent.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!--
      The shortcut component needs a registry KeyPath so MSI can track it.
      Writing to HKCU is fine for perUser installs (no elevation needed).
    -->
    <ComponentGroup Id="Shortcuts" Directory="AppMenuFolder">
      <Component Id="StartMenuShortcutComp" Guid="*">
        <Shortcut Id="StartMenuShortcut"
                  Name="Atomic Chat Agent"
                  Description="Connect your computer to Atomic Chat"
                  Target="[INSTALLFOLDER]atomic-chat-agent.exe" />
        <RemoveFolder Id="CleanAppMenu" Directory="AppMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\AtomicChat\Agent"
                       Name="Installed"
                       Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ── Features ────────────────────────────────────────────────────── -->

    <Feature Id="Complete" Title="Atomic Chat Agent" Level="1">
      <ComponentGroupRef Id="AgentBinary" />
      <ComponentGroupRef Id="Shortcuts" />
    </Feature>

    <!-- ── UI ──────────────────────────────────────────────────────────── -->

    <!-- WixUI_Minimal: license agreement → Install → progress → finish -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="license.rtf" />

  </Package>
</Wix>
