          <attvalue for_="2" value="python" />
          <attvalue for_="3" value="This function decrypts the provided blob by checking for an XOR prefix or using AES-GCM decryption based on the available libraries. It raises a RuntimeError if the blob was encrypted with the cryptography library but that library is not currently installed." />
        </attvalues>
      </node>
