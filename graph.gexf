        <attvalues>
          <attvalue for_="0" value="Function" />
          <attvalue for_="1" value="auth/credentials.py" />
          <attvalue for_="2" value="python" />
          <attvalue for_="3" value="This function encrypts the provided data bytes using AES-GCM if the cryptography library is available, otherwise it falls back to an insecure XOR encryption. It returns the nonce concatenated with the ciphertext for AES-GCM, or a prefixed XOR-encrypted byte string for the fallback method." />
